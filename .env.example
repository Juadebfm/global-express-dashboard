VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
VITE_API_BASE_URL=https://your-api-host.example.com/api/v1

# Cloudflare Turnstile site key (public, safe to commit).
# Empty / unset = dev bypass: the <TurnstileGate> primitive returns a dummy
# token so localhost works without setup. The BE middleware no-ops the same
# way when TURNSTILE_SECRET_KEY is unset.
# Test keys (always-pass / always-fail / always-interactive):
#   https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=
VITE_LAUNCH_GATE_ENABLED=false
VITE_LAUNCH_GATE_TARGET_UTC=2026-04-18T00:00:00Z
VITE_PROVISIONING_GATE_ENABLED=false
VITE_PROVISIONING_GATE_TARGET_UTC=2026-04-20T00:00:00Z
